{
  "name": "pl-preview-vscode",
  "displayName": "PrairieLearn Preview",
  "description": "Preview PrairieLearn questions side by side in VS Code. Save your edits and the rendered question refreshes instantly from a local server running in Docker or Podman.",
  "version": "1.2.0",
  "publisher": "runjuu",
  "license": "MIT",
  "icon": "media/icon.png",
  "pricing": "Free",
  "homepage": "https://github.com/runjuu/pl-preview-vscode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runjuu/pl-preview-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/runjuu/pl-preview-vscode/issues"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=24"
  },
  "categories": [
    "Education",
    "Visualization"
  ],
  "keywords": [
    "PrairieLearn",
    "Prairie Learn",
    "PairieLearn",
    "PririeLearn",
    "PrarieLearn",
    "PraiieLearn",
    "PraireLearn",
    "PraireeLearn",
    "PraireiLearn",
    "PraerieLearn",
    "PrairiLearn",
    "PrairyLearn",
    "ParirieLearn",
    "PL",
    "PrairieLearn VS Code extension",
    "question",
    "preview",
    "live preview",
    "authoring",
    "instructor",
    "teaching",
    "education",
    "assessment",
    "autograder",
    "freeform",
    "course",
    "Docker",
    "Podman"
  ],
  "galleryBanner": {
    "color": "#0e2a3b",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/infoCourse.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "plPreview.openPreview",
        "title": "Open Preview",
        "category": "PrairieLearn Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "plPreview.refreshPreview",
        "title": "Refresh preview",
        "category": "PrairieLearn Preview"
      },
      {
        "command": "plPreview.newVariant",
        "title": "New variant",
        "category": "PrairieLearn Preview"
      },
      {
        "command": "plPreview.showLogs",
        "title": "Show logs",
        "category": "PrairieLearn Preview"
      },
      {
        "command": "plPreview.stopServers",
        "title": "Stop preview servers",
        "category": "PrairieLearn Preview"
      },
      {
        "command": "plPreview.deleteOldImages",
        "title": "Delete old preview images",
        "category": "PrairieLearn Preview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "plPreview.openPreview",
          "when": "resourceScheme == file && plPreview.activeFileIsPreviewable",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "PrairieLearn Preview",
      "properties": {
        "plPreview.containerRuntime": {
          "type": "string",
          "enum": [
            "auto",
            "docker",
            "podman",
            "custom"
          ],
          "enumDescriptions": [
            "Auto-detect: use Docker if reachable, otherwise Podman.",
            "Always use Docker.",
            "Always use Podman.",
            "Use the endpoint in plPreview.containerHost."
          ],
          "default": "auto",
          "markdownDescription": "Which Docker-Engine-API-compatible container runtime to use for previews. `auto` tries Docker's socket, then Podman's; Colima, Rancher Desktop, and OrbStack are reached through their Docker-compatible socket."
        },
        "plPreview.containerHost": {
          "type": "string",
          "default": "",
          "markdownDescription": "Container runtime endpoint, e.g. `unix:///run/user/1000/podman/podman.sock`, `tcp://127.0.0.1:2375`, or `npipe:////./pipe/podman-machine-default`. Required when `#plPreview.containerRuntime#` is `custom`; when set with `auto`, it overrides detection. Leave blank to auto-detect."
        },
        "plPreview.enableWorkspaces": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Preview workspace questions. This mounts the container runtime socket into the preview container so it can launch workspace containers, which grants previewed course code container-runtime access (root-equivalent with a rootful daemon). It applies only in a trusted workspace on a socket-based runtime; other question types preview regardless."
        }
      }
    }
  },
  "sponsor": {
    "url": "https://github.com/sponsors/runjuu"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Workspace question previews run course-provided code in Docker/Podman containers, so they require a trusted workspace. Other question types preview normally."
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --external:cpu-features --external:*.node --outfile=out/extension.js --sourcemap",
    "build": "tsc -p ./tsconfig.build.json --noEmit && pnpm run clean && pnpm run bundle",
    "watch": "pnpm run bundle -- --watch",
    "typecheck": "tsc -p ./tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "test:contract": "tsx --test tests/previewServer.integration.test.ts",
    "update-image": "node scripts/update-preview-image.mjs",
    "test:coverage": "c8 node --import tsx --test tests/*.test.ts",
    "release:check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "release": "bumpp --git-check --execute \"pnpm run release:check\"",
    "release:patch": "bumpp --release patch --git-check --execute \"pnpm run release:check\"",
    "release:minor": "bumpp --release minor --git-check --execute \"pnpm run release:check\"",
    "release:major": "bumpp --release major --git-check --execute \"pnpm run release:check\"",
    "vscode:prepublish": "pnpm run build"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.90.0",
    "bumpp": "^11.1.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "dockerode": "^4.0.12"
  }
}
